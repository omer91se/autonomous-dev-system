# Port Configuration
# Change these if default ports are taken
NEXT_PUBLIC_UI_PORT=3000
NEXT_PUBLIC_WS_PORT=3001

# WebSocket Server URL (constructed from port above)
NEXT_PUBLIC_WS_URL=ws://localhost:3001

# Example: If port 3000 is taken, use:
# NEXT_PUBLIC_UI_PORT=3002
# NEXT_PUBLIC_WS_PORT=3003
# NEXT_PUBLIC_WS_URL=ws://localhost:3003
